, exist_ok=True)\n\n# This analysis uses only one year; rows outside it are dropped from the subsets.\nYEAR = 2021\n\n# Discover the input Parquet files.\nparquet_files = sorted(INDIR.glob(\"*.parquet\"))\nprint(f\"Found {len(parquet_files)} Parquet file(s):\")\nfor f in parquet_files:\n    print(f\"  {f.name}\")","key":"eMBKbRJIWv"},{"type":"outputs","id":"PFzBbux-Q-bfcVbEWb4qB","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Found 6 Parquet file(s):\n  LGR-1.parquet\n  LGR-2R.parquet\n  LGR-3.parquet\n  QCL-1.parquet\n  QCL-2R.parquet\n  QCL-3.parquet\n"},"children":[],"key":"pVxmNHsqWC"}],"key":"m0c1YkLIvw"}],"key":"yucVtR1sog"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Subset each file and save","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ZuOuOBbLQd"}],"identifier":"subset-each-file-and-save","label":"Subset each file and save","html_id":"subset-each-file-and-save","implicit":true,"key":"NwcZrCFRAp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"For each version: load the full table, keep ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"LdyjwTI3Ad"},{"type":"inlineCode","value":"KEEP_COLS","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"qUIHVcmQWt"},{"type":"text","value":" (preserving the\ntimestamp index), warn about any requested columns that are absent, and save the\nsubset under the same version-code filename.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yMY03BGnGw"}],"key":"jroJRDCmnm"}],"key":"HFupiWswvo"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-08T14:34:03.883641900Z","start_time":"2026-06-08T14:34:02.866201800Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"saved = {}\nfor f in parquet_files:\n    code = f.stem  # version code, e.g. 'LGR-1'\n    print(f\"\\n=== {code} ===\")\n\n    df = load_parquet(filepath=str(f))\n\n    # Keep only the analysis year.\n    df = df.loc[df.index.year == YEAR]\n\n    present = [c for c in KEEP_COLS if c in df.columns]\n    missing = [c for c in KEEP_COLS if c not in df.columns]\n    if missing:\n        print(f\"  WARNING: {len(missing)} requested column(s) not found: {missing}\")\n\n    subset = df[present]\n    print(f\"  kept {subset.shape[1]} / {len(KEEP_COLS)} columns, \"\n          f\"{subset.shape[0]} rows in {YEAR}\")\n\n    filepath = save_parquet(filename=code, data=subset, outpath=str(OUTDIR))\n    saved[code] = filepath","key":"Yycg4UEjnB"},{"type":"outputs","id":"pFskKXr5-XZ7hOCYeohzx","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"\n=== LGR-1 ===\n"},"children":[],"key":"VqwHJR2BWa"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\01-eddypro_fluxes_level-1_parquet\\LGR-1.parquet (0.047 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\01-eddypro_fluxes_level-1_parquet\\LGR-1.parquet (0.047 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"dMn6VY8DlA"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"  kept 4 / 4 columns, 7803 rows in 2021\n"},"children":[],"key":"l40x7dt7I5"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Saved file ..\\data\\02-eddypro_fluxes_