ns.md","dataUrl":"/processing-versions.json","internal":true,"protocol":"file","key":"Ib7LLj3gbs"},{"type":"text","value":", and the diive workflow that\napplies it.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xtvZfwIluH"}],"key":"Ql5QdvjabP"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The PWB time-lag method","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"yJmQSCGRBn"}],"identifier":"the-pwb-time-lag-method","label":"The PWB time-lag method","html_id":"the-pwb-time-lag-method","implicit":true,"key":"Xb7Qq8fLhq"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"For reactive and trace gases such as N₂O and CH₄, the gas-wind cross-correlation\nis often too weak for conventional covariance-maximization (CM) to pinpoint the\ntime lag reliably. The ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"lMoeWPyhD8"},{"type":"inlineCode","value":"*-4","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"hpJi9JsNmJ"},{"type":"text","value":" versions instead use the Pre-Whitening with\nBlock-bootstrap (PWB) method (Vitale et al., 2024), as implemented in ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"IyAP2dnvia"},{"type":"inlineCode","value":"diive","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"psluMkesgt"},{"type":"text","value":". It\nworks in two stages.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"fpiwmj5JoK"}],"key":"nMzLHl4jbn"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Pre-whitening.","position":{"start"