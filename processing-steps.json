:{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"QoGO9jlg7X"}],"key":"sNmo0FHasE"},{"type":"text","value":" An AR(","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"yalMG4Pa4a"},{"type":"emphasis","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"p","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"uvBCQPxose"}],"key":"MzIgjOKCtN"},{"type":"text","value":") filter (order chosen by AIC) removes serial\nautocorrelation from each series before the cross-correlation function (CCF) is\ncomputed. Turbulent wind and trace-gas series are strongly autocorrelated, which\nbroadens and distorts the CCF peak. Whitening the residuals sharpens the peak and\ngives a cleaner lag estimate.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"hQwEEHIjKR"}],"key":"pehM8A6GLo"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Block-bootstrap.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"umDznGlqlO"}],"key":"zFWUTEoFzT"},{"type":"text","value":" Instead of a single CCF over the whole averaging period, the\nmethod draws ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"znM1Wlqzwl"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"N","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"G8p5vTZ96X"}],"key":"MXfaO6ErNs"},{"type":"text","value":"ᵦ resampled series by moving-block resampling, where overlapping\nblocks of length ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"Jd6nVszuMG"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end"