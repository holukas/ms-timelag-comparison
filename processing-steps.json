ns.md","dataUrl":"/processing-versions.json","internal":true,"protocol":"file","key":"oL6HSQS2Ot"},{"type":"text","value":", and the diive workflow that\napplies it.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ySq7OEZnho"}],"key":"TYIRH7i6dW"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The PWB time-lag method","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"OI6Qs5H3fq"}],"identifier":"the-pwb-time-lag-method","label":"The PWB time-lag method","html_id":"the-pwb-time-lag-method","implicit":true,"key":"HUceXqRs7v"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"For reactive and trace gases such as N₂O and CH₄, the gas-wind cross-correlation\nis often too weak for conventional covariance-maximization (CM) to pinpoint the\ntime lag reliably. The ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"UtP9JL3gVb"},{"type":"inlineCode","value":"*-4","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"epqHdVgsXW"},{"type":"text","value":" versions instead use the Pre-Whitening with\nBlock-bootstrap (PWB) method (Vitale et al., 2024), as implemented in ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"DdRfktLBFZ"},{"type":"inlineCode","value":"diive","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"d2ctWyZa2e"},{"type":"text","value":". It\nworks in two stages.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"TCivC6RD7V"}],"key":"dQkRlZFvRx"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Pre-whitening.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"xN9BocHuSQ"}],"key":"THPuwb7P5R"},{"type":"text","value":" An AR(","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"KP768D5kjj"},{"type":"emphasis","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"p","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"zx0ORXYi0m"}],"key":"Kxv0H2PB24"},{"type":"text","value":") filter (order chosen by AIC) removes serial\nautocorrelation from each series before the cross-correlation function (CCF) is\ncomputed. Turbulent wind and trace-gas series are strongly autocorrelated, which\nbroadens and distorts the CCF peak. Whitening the residuals sharpens the peak and\ngives a cleaner lag estimate.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"w2HNXwtk2L"}],"key":"eAo0sVp7lp"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Block-bootstrap.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"sT5tcnzUis"}],"key":"HVEbJPKFGF"},{"type":"text","value":" Instead of a single CCF over the whole averaging period, the\nmethod draws ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"D9Ej2HOUlq"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"N","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"tDJK1W0xzE"}],"key":"ikGXXXT3z6"},{"type":"text","value":"ᵦ resampled series by moving-block resampling, where overlapping\nblocks of length ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"UC3Vh6uRFP"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end"