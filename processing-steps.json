ns.md","dataUrl":"/processing-versions.json","internal":true,"protocol":"file","key":"g9ATLNeyLH"},{"type":"text","value":", and the diive workflow that\napplies it.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mCY0bTRzQH"}],"key":"QAAtMr7xi2"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The PWB time-lag method","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"rQCoPLH1Nn"}],"identifier":"the-pwb-time-lag-method","label":"The PWB time-lag method","html_id":"the-pwb-time-lag-method","implicit":true,"key":"cLSOBuVNb5"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"For reactive and trace gases such as N₂O and CH₄, the gas-wind cross-correlation\nis often too weak for conventional covariance-maximization (CM) to pinpoint the\ntime lag reliably. The ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"mkaAz861XL"},{"type":"inlineCode","value":"*-4","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"EjUXws4llA"},{"type":"text","value":" versions instead use the Pre-Whitening with\nBlock-bootstrap (PWB) method (Vitale et al., 2024), as implemented in ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"PeVstOaTQV"},{"type":"inlineCode","value":"diive","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"z8ZumgD7Zr"},{"type":"text","value":". It\nworks in two stages.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"DjltO7B5GI"}],"key":"CkEBVVsItL"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"strong","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"Pre-whitening.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"JU1H0nfjYd"}],"key":"FoSJE1Kuah"},{"type":"text","value":" An AR(","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"sYL2RN4dpY"},{"type":"emphasis","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"p","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"obVXSsI6CI"}],"key":"o8Q2P8yl6r"},{"type":"text","value":") filter (order chosen by AIC) removes serial\nautocorrelation from each series before the cross-correlation function (CCF) is\ncomputed. Turbulent wind and trace-gas series are strongly autocorrelated, which\nbroadens and distorts the CCF peak. Whitening the residuals sharpens the peak and\ngives a cleaner lag estimate.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"l7PteNEEFP"}],"key":"k8FzuX5HuO"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Block-bootstrap.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"DOg9PJxC3A"}],"key":"It1Kwqt0LK"},{"type":"text","value":" Instead of a single CCF over the whole averaging period, the\nmethod draws ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"FH3SFLklcI"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"N","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"Mp9u6HPIyU"}],"key":"rVXf8eVYmm"},{"type":"text","value":"ᵦ resampled series by moving-block resampling, where overlapping\nblocks of length ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"dsqp0UQqPp"},{"type":"emphasis","position":{"start":{"line":21,"column":1},"end"