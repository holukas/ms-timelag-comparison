:[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Imports","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"W5NExyWS6h"}],"identifier":"imports","label":"Imports","html_id":"imports","implicit":true,"key":"PmSvGKswQB"}],"key":"ZrXjbKUVQD"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T15:52:55.727164300Z","start_time":"2026-06-04T15:52:55.567326800Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"import base64\nfrom datetime import datetime\nfrom pathlib import Path\n\nfrom IPython.display import HTML, display\n\nNB_START = datetime.now()  # notebook start time (reported in the last cell)","key":"AnCuPDWBM3"},{"type":"outputs","id":"_-DeoVHpjSq60ShqRjiNx","children":[],"key":"riy2qCIvi5"}],"key":"nu99f64iSz"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Gallery","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VcNvK2kJM9"}],"identifier":"gallery","label":"Gallery","html_id":"gallery","implicit":true,"key":"Bg7XyzCub1"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"Images are base64-embedded so the page is self-contained and the paths resolve\nin the built book.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"xMiVIAIszu"}],"key":"E0K9wDm5ar"}],"key":"Ir8SqQ0n9Q"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T15:52:56.438805600Z","start_time":"2026-06-04T15:52:55.730165800Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"FIGDIR = Path(\"../figures\")\nEXTS = (\"*.png\", \"*.jpg\", \"*.jpeg\", \"*.gif\", \"*.svg\")\n\nimages = sorted(p for ext in EXTS for p in FIGDIR.glob(ext))\nprint(f\"Found {len(images)} figure(s) in {FIGDIR}\")\n\nMIME = {\".png\": \"image/png\", \".jpg\": \"image/jpeg\", \".jpeg\": \"image/jpeg\",\n        \".gif\": \"image/gif\", \".svg\": \"image/svg+xml\"}\n\ncards = []\nfor p in images:\n    b64 = base64.b64encode(p.read_bytes()).decode()\n    mime = MIME.get(p.suffix.lower(), \"image/png\")\n    cards.append(\n        '<figure style=\"margin:0\">'\n        f'<img src=\"data:{mime};base64,{b64}\" '\n        'style=\"width:100%;height:auto;border:1px solid #ccc;border-radius:4px\"/>'\n        f'<figcaption style=\"font-size:0.8em;text-align:center;word-break:break-all\">{p.name}</figcaption>'\n        '</figure>'\n    )\n\nif cards:\n    grid = (\n        '<div style=\"display:grid;'\n        'grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem\">'\n        + \"\".join(cards) + \"</div>\"\n    )\n    display(HTML(grid))\nelse:\n    print(\"No figures found yet. Run the plotting notebooks first.\")","key":"romLQyxCd9"},{"type":"outputs","id":"u5fvqzJT7lMYt6bHh23Vi","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Found 4 figure(s) in ..\\figures\n"},"children":[],"key":"KtFfVgKcRm"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<IPython.core.display.HTML object>","content_type":"text/plain"},"text/html":{"content_type":"text/html","hash":"3c2cc296bef0abe44df77f6cfb82f1e3","path":"/ms-timelag-comparison/build/3c2cc296bef0abe44df77f6cfb82f1e3.html"}}},"children":[],"key":"AFZebHoMQk"}],"key":"ZgwaoM5NDj"}],"key":"IVrwuJ7sSL"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Runtime","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"W1fqMENfDV"}],"identifier":"runtime","label":"Runtime","html_id":"runtime",