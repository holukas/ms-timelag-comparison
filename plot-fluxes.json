","value":"FIGSIZE","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"YDsAq0qflN"},{"type":"text","value":" / ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"vnTxv4nylQ"},{"type":"inlineCode","value":"DPI","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"viOvICyfny"},{"type":"text","value":" for publication-ready output.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"QTEv12zS1r"}],"key":"EXwP4ZJvs6"}],"key":"xnKlt8kX0F"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Imports","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kLyhedL50O"}],"identifier":"imports","label":"Imports","html_id":"imports","implicit":true,"key":"ZRfYc1hY0L"}],"key":"uWaCgqp8Ml"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T13:07:54.410047800Z","start_time":"2026-06-04T13:07:54.331409600Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"from datetime import datetime\nfrom pathlib import Path\n\nimport matplotlib.dates as mdates\nimport matplotlib.pyplot as plt\nimport numpy as np\n\nfrom diive.core.io.files import load_parquet\n\nNB_START = datetime.now()  # notebook start time (reported in the last cell)","key":"WG26yMzwXC"},{"type":"outputs","id":"nFvjxR3Z45srTgsLDrdrL","children":[],"key":"l9Rqv5Y72I"}],"key":"ZiHVuc54I8"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Configuration","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LbNgSwcLpa"}],"identifier":"configuration","label":"Configuration","html_id":"configuration","implicit":true,"key":"XOed4Eoe7z"}],"key":"Zfj70cmGMd"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T13:07:54.780219500Z","start_time":"2026-06-04T13:07:54.448607800Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"SUBSETDIR = Path(\"../data/02-eddypro_fluxes_level-1_parquet_subsets\")\nFIGDIR = Path(\"../figures\")\nFIGDIR.mkdir(parents=True, exist_ok=True)\n\n# Figure size / resolution. Kept small here — these are intermediate figures.\n# 12 x 6 inches at 100 DPI = 1200 x 600 px. Increase for publication output.\nFIGSIZE = (12, 6)\nDPI = 150\n\n# One figure per analyzer x gas. Columns of each figure = that analyzer's variants.\nANALYZERS = {\n    \"QCL\": [\"QCL-1\", \"QCL-2R\", \"QCL-3\"],\n    \"LGR\": [\"LGR-1\", \"LGR-2R\", \"LGR-3\"],\n}\n# Per gas: the flux variable (top row) and the time-lag-used variable (bottom row).\nGASES = {\n    \"N2O\": {\"flux\": \"FN2O\", \"lag\": \"N2O_TLAG_USED\"},\n    \"CH4\": {\"flux\": \"FCH4\", \"lag\": \"CH4_TLAG_USED\"},\n}\n# Distinct colors for the two rows (ColorBrewer Dark2): flux vs. lag.\nFLUX_COLOR = \"#1b9e77\"  # teal\nLAG_COLOR = \"#d95f02\"   # orange\n\n# Robust flux y-range: clip the flux axis to this percentile range (per figure)\n# so outliers don't flatten the signal. The lag axis is left to autoscale.\nPCTL = (1, 99)\n\n# Load the needed subsets.\ncodes = [c for variants in ANALYZERS.values() for c in variants]\ndata = {c: load_parquet(filepath=str(SUBSETDIR / f\"{c}.parquet\")) for c in codes}\nfor c in codes:\n    print(f\"{c}: {data[c].shape[0]} rows, {data[c].index.min()} -> {data[c].index.max()}\")","key":"PpVU4U9Kxw"},{"type":"outputs","id":"NHb41h11XLdjCyFQMOyPO","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-1.parquet (0.006 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-1.parquet (0.006 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"STe8gMfehv"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-2R.parquet (0.005 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-2R.parquet (0.005 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"RtedbtbCOb"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-3.parquet (0.006 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\QCL-3.parquet (0.006 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"DA0TT4aGh2"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-1.parquet (0.006 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-1.parquet (0.006 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"c68BG2ngtS"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-2R.parquet (0.004 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-2R.parquet (0.004 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"PnhWF41DUU"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"  \u001b[36m>\u001b[0m Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-3.parquet (0.005 seconds).\n","content_type":"text/plain"},"text/html":{"content":"<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\">  <span style=\"color: #008080; text-decoration-color: #008080\">&gt;</span> Loaded .parquet file ..\\data\\02-eddypro_fluxes_level-1_parquet_subsets\\LGR-3.parquet (0.005 seconds).\n</pre>\n","content_type":"text/html"}}},"children":[],"key":"rqcRIPneAy"},{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"QCL-1: 9642 rows, 2020-12-31 19:15:00 -> 2021-07-20 15:45:00\nQCL-2R: 9642 rows, 2020-12-31 19:15:00 -> 2021-07-20 15:45:00\nQCL-3: 20790 rows, 2020-05-13 13:15:00 -> 2021-07-20 15:45:00\nLGR-1: 7805 rows, 2021-07-22 10:45:00 -> 2022-01-01 00:45:00\nLGR-2R: 7805 rows, 2021-07-22 10:45:00 -> 2022-01-01 00:45:00\nLGR-3: 16768 rows, 2021-07-22 10:45:00 -> 2022-07-06 18:15:00\n"},"children":[],"key":"ShUn3HSXvu"}],"key":"bEzofOvVqZ"}],"key":"g0mfaECNtY"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Figures","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fqGqFlNPjG"}],"identifier":"figures","label":"Figures","html_id":"figures","implicit":true,"key":"kqQcLGw5F4"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"One figure per analyzer x gas: flux (top) over time lag used (bottom), variants\nas columns.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"r14YhlrskO"}],"key":"v92snB7tVq"}],"key":"XRVkrpA9gh"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T13:08:09.680935Z","start_time":"2026-06-04T13:07:54.785731Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def robust_ylim(values, pctl=PCTL, pad_frac=0.05):\n    \"\"\"Percentile-based y-limits with a small symmetric pad.\"\"\"\n    lo, hi = np.nanpercentile(values, pctl)\n    pad = pad_frac * (hi - lo)\n    return lo - pad, hi + pad\n\n\nfor analyzer, variants in ANALYZERS.items():\n    for gas, v in GASES.items():\n        fluxvar, lagvar = v[\"flux\"], v[\"lag\"]\n\n        # Robust flux range across this figure's variants.\n        flux_vals = np.concatenate([data[c][fluxvar].to_numpy().ravel() for c in variants])\n        flux_ylim = robust_ylim(flux_vals)\n\n        fig, axes = plt.subplots(\n            nrows=2, ncols=len(variants),\n            figsize=FIGSIZE,\n            sharex=\"col\",   # flux and its lag share the time axis\n            sharey=\"row\",   # all flux panels share scale; all lag panels share scale\n            constrained_layout=True,\n        )\n\n        for ci, code in enumerate(variants):\n            df = data[code]\n\n            # Top: flux\n            ax_top = axes[0, ci]\n            ax_top.scatter(df.index, df[fluxvar], s=3, alpha=0.5,\n                           color=FLUX_COLOR, edgecolors=\"none\")\n            ax_top.set_title(code, fontweight=\"bold\")\n            ax_top.grid(True, alpha=0.3)\n            ax_top.set_ylim(flux_ylim)\n\n            # Bottom: time lag used\n            ax_bot = axes[1, ci]\n            ax_bot.scatter(df.index, df[lagvar], s=3, alpha=0.5,\n                           color=LAG_COLOR, edgecolors=\"none\")\n            ax_bot.grid(True, alpha=0.3)\n            loc = mdates.AutoDateLocator()\n            ax_bot.xaxis.set_major_locator(loc)\n            ax_bot.xaxis.set_major_formatter(mdates.ConciseDateFormatter(loc))\n\n        axes[0, 0].set_ylabel(\"Flux (nmol m$^{-2}$ s$^{-1}$)\")\n        axes[1, 0].set_ylabel(\"Time lag used (s)\")\n        fig.suptitle(f\"{analyzer} - {gas}: flux (top) and time lag used (bottom), by variant\",\n                     fontsize=13, fontweight=\"bold\")\n\n        out = FIGDIR / f\"03_{analyzer.lower()}_{gas.lower()}.png\"\n        fig.savefig(out, dpi=DPI, bbox_inches=\"tight\")\n        print(f\"Saved {out}\")\n        plt.show()","key":"gZlfqxnZ0e"},{"type":"outputs","id":"LtbKkbgf0OgroMW4I6jun","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Saved ..\\figures\\03_qcl_n2o.png\n"},"children":[],"key":"hiPONzfmNV"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x600 with 6 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"5f68c02cf0c4eec59f27fdf7161ce99f","path":"/ms-timelag-comparison/build/5f68