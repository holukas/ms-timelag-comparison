tdout","output_type":"stream","text":"Found 6 flux file(s):\n  eddypro_LGR-1_FR-20260521-103649_fluxnet_2026-05-21T234627_adv.csv\n  eddypro_LGR-2R_FR-20260527-195011_fluxnet_2026-05-28T092652_adv.csv\n  eddypro_LGR-3_2021_2_2022_1_LGR_eddypro_CH-CHA_FR-20240809-181345_fluxnet_2024-08-10T185331_adv.csv\n  eddypro_QCL-1_FR-20260521-103816_fluxnet_2026-05-22T021605_adv.csv\n  eddypro_QCL-2R_FR-20260527-194920_fluxnet_2026-05-28T112056_adv.csv\n  eddypro_QCL-3_2020_4_5_2021_1_QCL_eddypro_CH-CHA_FR-20240809-181351_fluxnet_2024-08-10T220247_adv.csv\n"},"children":[],"key":"IOy4KfHUQ3"}],"key":"a93ecx6W3B"}],"key":"f6P3XIUHYn"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Version codes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"lyWLt9IWGw"}],"identifier":"version-codes","label":"Version codes","html_id":"version-codes","implicit":true,"key":"qmWapEHmpY"}],"key":"IkXVE5XZk6"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-04T11:59:33.537720700Z","start_time":"2026-06-04T11:59:33.386780200Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def version_code(filename: str) -> str:\n    \"\"\"Extract the processing-version code (e.g. 'LGR-1', 'QCL-2R') from a filename.\"\"\"\n    match = re.search(r\"eddypro_([A-Z]+-\\d+R?)_\", filename)\n    if not match:\n        raise ValueError(f\"Could not extract a version code from: {filename}\")\n    return match.group(1)\n\n\n# Map each input file to its version code (the output Parquet name).\nfor f in csv_files:\n    print(f\"{version_code(f.name):>8}  <-  {f.name}\")","key":"Pw40oF7q0t"},{"type":"outputs","id":"014CLTBFNlo2MOF04rLN-","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"   LGR-1  <-  eddypro_LGR-1_FR-20260521-103649_fluxnet_2026-05-21T234627_ad