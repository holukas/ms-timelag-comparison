8T14:33:36.031607900Z","start_time":"2026-06-08T14:33:35.959516400Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# Input / output folders (relative to the notebooks/ directory).\nINDIR = Path(\"../data/00-eddypro_fluxes_level-1\")\nOUTDIR = Path(\"../data/01-eddypro_fluxes_level-1_parquet\")\nOUTDIR.mkdir(parents=True, exist_ok=True)\n\n# Discover the input CSVs.\ncsv_files = sorted(INDIR.glob(\"eddypro_*_adv.csv\"))\nprint(f\"Found {len(csv_files)} flux file(s):\")\nfor f in csv_files:\n    print(f\"  {f.name}\")","key":"eNOEMhHv53"},{"type":"outputs","id":"8mDgC4BhCQzEEd7VcHbh-","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Found 6 flux file(s):\n  eddypro_LGR-1_FR-20260521-103649_fluxnet_2026-05-21T234627_adv.csv\n  eddypro_LGR-2R_FR-20260527-195011_fluxnet_2026-05-28T092652_adv.csv\n  eddypro_LGR-3_2021_2_2022_1_LGR_eddypro_CH-CHA_FR-20240809-181345_fluxnet_2024-08-10T185331_adv.csv\n  eddypro_QCL-1_FR-20260521-103816_fluxnet_2026-05-22T021605_adv.csv\n  eddypro_QCL-2R_FR-20260527-194920_fluxnet_2026-05-28T112056_adv.csv\n  eddypro_QCL-3_2020_4_5_2021_1_QCL_eddypro_CH-CHA_FR-20240809-181351_fluxnet_2024-08-10T220247_adv.csv\n"},"children":[],"key":"RsRNIQofr2"}],"key":"VhcpJgbUEz"}],"key":"nIDNAN9UmN"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Version codes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Uu1F1VtJW1"}],"identifier":"version-codes","label":"Version codes","html_id":"version-codes","implicit":true,"key":"N4hcmbgDVT"}],"key":"vE67OY63qM"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-06-08T14:33:36.063239300Z","start_time":"2026-06-08T14:33:36.033575800Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def version_code(filename: str) -> str:\n    \"\"\"Extract the processing-version code (e.g. 'LGR-1', 'QCL-2R') from a filename.\"\"\"\n    match = re.search(r\"eddypro_([A-Z]+-\\d+R?)_\", filename)\n    if not match:\n        raise ValueError(f\"Could not extract a version code from: {filename}\")\n    return match.group(1)\n\n\n# Map each input file to its version code (the output Parquet name).\nfor f in csv_files:\n    print(f\"{version_code(f.name):>8}  <-  {f.name}\")","key":"jBovz9upfD"},{"type":"outputs","id":"cY98SpgzUaRpwsa0bWy8g","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"   LGR-1  <-  eddypro_LGR-1_FR-20260521-103649_fluxnet_2026-05-21T234627_adv.csv\n  LGR-2R  <-  eddypro_LGR-2R_FR-20260527-195011_fluxnet_2026-05-28T092652_adv.csv\n   LGR-3  <-  eddypro_LGR-3_2021_2_2022_1_LGR_eddypro_CH-CHA_FR-20240809-181345_fluxnet_2024-08-10T185331_adv.csv\n   QCL-1  <-  eddypro_QCL-1_FR-20260521-103816_fluxnet_2026-05-22T021605_adv.csv\n  QCL-2R  <-  eddypro_QCL-2R_FR-20260527-194920_fluxnet_2026-05-28T112056_adv.csv\n   QCL-3  <-  eddypro_QCL-3_2020_4_5_2021_1_QCL_eddypro_CH-CHA_FR-20240809-181351_fluxnet_2024-08-10T220247_adv.csv\n"},"children":[],"key":"EMRuzHG61v"}],"key":"xlm17R0mxS"}],"key":"EXD7nXy1Ik"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Read each CSV and save as Parquet","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"AIsg0B1ZHt"}],"identifier":"read-each-csv-and-save-as-parquet","label":"Read each CSV and save as Parquet","html_id":"read-each-csv-and-save-as-parquet","implicit":true,"key":"MmZVie0mDH"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"inlineCode","value":"ReadFileType","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ir4PiD5Ysi"},{"type":"text","value":" returns th