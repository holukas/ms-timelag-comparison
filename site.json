{"version":3,"kind":"Article","sha256":"9aee32d1cc09f7df8839ddfbc1a34ea87d6c8de1dc16517bec6caf362af2728f","slug":"site","location":"/docs/site.md","dependencies":[],"frontmatter":{"title":"Study site","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Lukas Hörtnagl","given":"Lukas","family":"Hörtnagl"},"name":"Lukas Hörtnagl","email":"lukas.hoertnagl@usys.ethz.ch","affiliations":["ETH Zürich"],"id":"contributors-dev\\manuscripts\\ms-timelag-comparison\\myst-generated-uid-0","corresponding":true}],"affiliations":[{"id":"ETH Zürich","name":"ETH Zürich"}],"exports":[{"format":"md","filename":"site.md","url":"/ms-timelag-comparison/build/site-0286f7ca434680c6de38736b33f31d9f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The flux measurements come from ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vrPrx568jn"},{"type":"strong","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Chamau (CH-Cha)","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"dr0yGKmhbW"}],"key":"EiZgtj2zgK"},{"type":"text","value":", an intensively managed\ngrassland in the pre-alpine valley bottom near Zug, Switzerland. The eddy\ncovariance tower sits at 47°12′36.8″ N, 8°24′38.3″ E (47.210227, 8.410645),\nabout 393 m above sea level. Mean annual temperature is 10.0 °C (2006 to 2024) and mean annual\nprecipitation is about 1134 mm.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yw5TOR3LsZ"}],"key":"rT669MiEgd"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"The grassland is a mixture of Italian ryegrass and white clover grown mainly for\nsilage, cut roughly six times a year, with occasional spring and fall grazing by\nsheep and cattle. The sward is renewed every 6 to 7 years by ploughing. The soil\nis a Cambisol/Gleysol on tertiary molasse with postglacial deposits from the\nReuss glacier, pH 5.3 in the top 10 cm.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"BGxhd8knMb"}],"key":"yihR7CdsIp"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Eddy covariance flux measurements started in July 2005 and cover net ecosystem\nexchange, evapotranspiration, sensible heat, and the greenhouse gases CH₄ and\nN₂O. Chamau is one of three grassland sites in the Swiss FluxNet network.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"IHY4R9tzlm"}],"key":"RauU8G9AXP"},{"type":"heading","depth":2,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Further information","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"GeC8sB0FTG"}],"identifier":"further-information","label":"Further information","html_id":"further-information","implicit":true,"key":"hojbqr6mGe"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":21,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Swiss FluxNet site info: ","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"WfAbfA0pb6"},{"type":"link","url":"https://www.swissfluxnet.ethz.ch/index.php/sites/site-info-ch-cha/","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"https://​www​.swissfluxnet​.ethz​.ch​/index​.php​/sites​/site​-info​-ch​-cha/","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"Ot08qedWWi"}],"urlSource":"https:/